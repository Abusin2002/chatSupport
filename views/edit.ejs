<!DOCTYPE html>
<html>
<head>
  <title>Edit FAQ</title>
  <style>
    /* -------------------- RESET & GLOBAL -------------------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(145deg, #f0f5fb 0%, #e1eaf3 100%);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
      color: #1b3346;
    }

    /* main content container (preserves exact body structure) */
    body > * {
      max-width: 720px;
      width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    /* ----- PAGE TITLE (elegant & refined) ----- */
    h1 {
      font-size: 3rem;
      font-weight: 480;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #1f4b6a, #1c405b);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 2.2rem;
      padding-bottom: 0.6rem;
      border-bottom: 3px solid rgba(255,255,255,0.5);
      display: inline-block;
    }

    /* ----- EDIT FORM (glassy card) ----- */
    form {
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(14px) saturate(180%);
      -webkit-backdrop-filter: blur(14px) saturate(180%);
      border: 1px solid rgba(255,255,255,0.8);
      border-radius: 44px;
      padding: 2.5rem 2.8rem 2.8rem 2.8rem;
      box-shadow: 0 30px 45px -28px rgba(10, 45, 70, 0.3);
      margin: 1rem 0 2rem 0;
    }

    /* inputs & textarea — clean, modern, floating */
    input, textarea {
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(170, 200, 230, 0.6);
      border-radius: 56px;
      padding: 18px 28px;
      font-size: 1.05rem;
      font-family: inherit;
      color: #142f45;
      outline: none;
      width: 100%;
      margin-bottom: 1.2rem;
      backdrop-filter: blur(4px);
      transition: all 0.2s ease;
      box-shadow: inset 0 2px 6px rgba(0,0,0,0.02);
    }

    textarea {
      border-radius: 28px;
      resize: vertical;
      min-height: 150px;
      line-height: 1.5;
    }

    input::placeholder, textarea::placeholder {
      color: #7f9fbf;
      font-weight: 350;
      font-style: italic;
    }

    input:focus, textarea:focus {
      border-color: #9bbfdf;
      background: rgba(255,255,255,0.9);
      box-shadow: 0 0 0 5px rgba(150, 200, 240, 0.2);
    }

    /* hide <br> tags — we use margin on inputs */
    form br {
      display: none;
    }

    /* update button — glassy, premium */
    button[type="submit"] {
      background: rgba(255,255,255,0.9);
      border: none;
      border-radius: 60px;
      padding: 18px 42px;
      font-size: 1.2rem;
      font-weight: 560;
      color: #19547a;
      letter-spacing: 0.5px;
      backdrop-filter: blur(8px);
      box-shadow: 0 16px 26px -18px #12405f, 0 0 0 1px rgba(255,255,255,1) inset;
      cursor: pointer;
      transition: 0.18s ease;
      border: 1px solid rgba(255,255,255,0.9);
      width: fit-content;
      margin: 1.5rem 0 1rem 0;
    }

    button[type="submit"]:hover {
      background: white;
      box-shadow: 0 24px 32px -20px #195787, 0 0 0 1px rgba(220, 235, 250, 1) inset;
      color: #0e3f62;
      transform: scale(1.02);
    }

    button[type="submit"]:active {
      transform: scale(0.98);
    }

    /* ----- BACK LINK (elegant, pill style) ----- */
    a {
      text-decoration: none;
      font-weight: 540;
      font-size: 1.1rem;
      padding: 14px 34px;
      border-radius: 60px;
      background: rgba(245, 250, 255, 0.7);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.9);
      color: #1f5f88;
      display: inline-block;
      transition: all 0.15s;
      box-shadow: 0 8px 16px -14px #1d5075;
      margin-top: 0.5rem;
    }

    a:hover {
      background: white;
      border-color: #b7d6f0;
      color: #10486b;
      box-shadow: 0 14px 22px -16px #195787;
      transform: translateY(-2px);
    }

    a:active {
      transform: translateY(1px);
    }

    /* ----- small responsive adjustments ----- */
    @media (max-width: 600px) {
      h1 { font-size: 2.4rem; }
      form { padding: 2rem 1.5rem; }
      input, textarea { padding: 16px 22px; }
    }

    /* soft animation */
    form, a {
      animation: rise 0.2s ease-out;
    }

    @keyframes rise {
      0% { opacity: 0.96; transform: translateY(6px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* preserve EJS tags exactly, style wraps them elegantly */
  </style>
</head>
<body>
  <h1>Edit FAQ</h1>

  <form action="/faqs/update/<%= faq._id %>" method="POST">
    <input type="text" name="category" value="<%= faq.category %>" required><br>
    <input type="text" name="keywords" value="<%= faq.keywords.join(', ') %>" required><br>
    <textarea name="answer_en" required><%= faq.answer_en %></textarea><br>
    <button type="submit">Update FAQ</button>
  </form>

  <a href="/faqs">Back to list</a>
</body>
</html>